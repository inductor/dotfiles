#!/bin/sh
{{ if eq .chezmoi.os "darwin" }}
# Install Homebrew packages
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile" || true

# Touch ID for sudo (macOS Sonoma+)
sudo tee /etc/pam.d/sudo_local > /dev/null << 'EOF'
auth       optional       /opt/homebrew/lib/pam/pam_reattach.so
auth       sufficient     pam_tid.so
EOF
brew install pam-reattach

# gh auth: github.com
if ! gh auth status --hostname github.com &>/dev/null; then
  gh auth login --hostname github.com --web
fi

# Rust toolchain
if ! command -v rustc &>/dev/null; then
  rustup-init -y --no-modify-path
fi

# Apple fonts (SF Pro, SF Mono)
for font_dmg in SF-Pro SF-Mono; do
  if ! ls /Library/Fonts/${font_dmg}*.otf &>/dev/null; then
    dmg_path="/tmp/${font_dmg}.dmg"
    curl -fsSL -o "$dmg_path" "https://devimages-cdn.apple.com/design/resources/download/${font_dmg}.dmg"
    mount_point=$(hdiutil attach "$dmg_path" -nobrowse | tail -1 | awk '{print $3}')
    sudo installer -pkg "${mount_point}"/*.pkg -target /
    hdiutil detach "$mount_point"
    rm -f "$dmg_path"
  fi
done

# Claude Code
if ! command -v claude &>/dev/null; then
  curl -fsSL https://claude.ai/install.sh | sh
fi

# Xcode
if ! xcodes installed 2>/dev/null | grep -q '^26'; then
  xcodes install "26"
fi
{{ end }}
