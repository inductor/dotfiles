#!/bin/sh
{{ if eq .chezmoi.os "darwin" }}
echo "==> Installing Homebrew packages..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile" || true

echo "==> Configuring Touch ID for sudo..."
sudo tee /etc/pam.d/sudo_local > /dev/null << 'EOF'
auth       optional       /opt/homebrew/lib/pam/pam_reattach.so
auth       sufficient     pam_tid.so
EOF
brew install pam-reattach </dev/null

echo "==> Checking GitHub CLI auth..."
if ! gh auth status --hostname github.com &>/dev/null; then
  gh auth login --hostname github.com --web
fi

echo "==> Checking Rust toolchain..."
if ! command -v rustc &>/dev/null; then
  rustup toolchain install stable --no-self-update
  rustup default stable
else
  echo "   Rust already installed, skipping"
fi

echo "==> Installing Apple fonts..."
for font_dmg in SF-Pro SF-Mono; do
  if ! ls /Library/Fonts/${font_dmg}*.otf &>/dev/null; then
    echo "   Downloading ${font_dmg}..."
    dmg_path="/tmp/${font_dmg}.dmg"
    curl -fsSL -o "$dmg_path" "https://devimages-cdn.apple.com/design/resources/download/${font_dmg}.dmg"
    mount_point=$(hdiutil attach "$dmg_path" -nobrowse | tail -1 | awk '{print $3}')
    sudo installer -pkg "${mount_point}"/*.pkg -target /
    hdiutil detach "$mount_point"
    rm -f "$dmg_path"
  else
    echo "   ${font_dmg} already installed, skipping"
  fi
done

echo "==> Setting up VS Code CLI..."
if [ -d "/Applications/Visual Studio Code.app" ] && [ ! -f "/opt/homebrew/bin/code" ]; then
  ln -sf "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" /opt/homebrew/bin/code
fi

echo "==> Checking Claude Code..."
if [ "${SKIP_CLAUDE_INSTALL:-}" = "1" ]; then
  echo "   Skipping Claude Code install (SKIP_CLAUDE_INSTALL=1)"
elif ! command -v claude &>/dev/null; then
  curl -fsSL https://claude.ai/install.sh | sh
else
  echo "   Claude Code already installed, skipping"
fi

echo "==> Checking Xcode..."
if command -v xcodes &>/dev/null; then
  if ! xcodes installed 2>/dev/null | grep -q '^26'; then
    xcodes install "26"
  else
    echo "   Xcode 26 already installed, skipping"
  fi
else
  echo "   xcodes not found, skipping Xcode install"
fi

echo "==> macOS setup complete!"
{{ end }}
