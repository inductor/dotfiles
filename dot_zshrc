[[ -d /opt/homebrew/share/zsh/site-functions ]] && fpath+=(/opt/homebrew/share/zsh/site-functions)
export PATH="$(brew --prefix git)/share/git-core/contrib/diff-highlight:$HOME/.local/bin:$HOME/go/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
export PATH="$HOME/.npm-global/bin:$PATH"

export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# Kubernetes
alias k=kubectl
alias kn=kubens
alias kx=kubectx

# Language managers
eval "$(jenv init -)" 2>/dev/null
eval "$(rbenv init - zsh)" 2>/dev/null
eval "$(fnm env --use-on-cd --shell zsh)" 2>/dev/null

eval "$(starship init zsh)"

# Modern CLI alternatives
alias ls='eza'
alias lart='eza -alr --sort=modified'
alias ll='eza -alh --git'
alias la='eza -a'
alias tree='eza --tree'
alias cat='bat -pp'
eval "$(zoxide init zsh --cmd cd)"

# ghq + fzf
alias repo="cd \$(ghq root)/\$(ghq list | fzf)"

# Google Cloud SDK (installed via brew cask)
if [ -f "$(brew --prefix)/share/google-cloud-sdk/path.zsh.inc" ]; then
  source "$(brew --prefix)/share/google-cloud-sdk/path.zsh.inc"
fi
if [ -f "$(brew --prefix)/share/google-cloud-sdk/completion.zsh.inc" ]; then
  source "$(brew --prefix)/share/google-cloud-sdk/completion.zsh.inc"
fi

[[ -f ~/.zshrc_local ]] && source ~/.zshrc_local
